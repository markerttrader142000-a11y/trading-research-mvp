# Local Alpaca credentials for this MVP.
# Copy this file to .env and fill the values locally.
# Do not commit or share .env.

ALPACA_ACCOUNT_LABEL=trading-bots
ALPACA_ACCOUNT_ID_HINT=PA30WVXBX8B
ALPACA_TRADING_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_PAPER=true

# Use the Paper Trading API key/secret pair for the selected account.
ALPACA_API_KEY=replace_with_your_paper_key
ALPACA_API_SECRET=replace_with_your_paper_secret

# cTrader Open API app credentials.
# Use the approved app credentials from https://openapi.ctrader.com
CTRADER_CLIENT_ID=replace_with_your_client_id
CTRADER_CLIENT_SECRET=replace_with_your_client_secret
CTRADER_REDIRECT_URI=http://localhost:8080/callback
CTRADER_SCOPE=accounts
CTRADER_ENV=demo

# ---------------------------------------------------------------------------
# LLM Providers — add the key for the provider you want to use.
# The system auto-detects: MISTRAL → ANTHROPIC → OPENAI → ... → mock
# ---------------------------------------------------------------------------

# Mistral AI (recommended: free tier available, fast JSON output)
# Get your key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=replace_with_your_mistral_key

# Anthropic Claude (optional)
# ANTHROPIC_API_KEY=replace_with_your_anthropic_key

# OpenAI — GPT-4.1-nano (sentiment/impact/validation agents) + GPT-4.1-mini (trade planner)
# Cost hierarchy: nano (cheapest) → mini → gpt-4o (reserved for critical decisions)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=replace_with_your_openai_key

# Perplexity — real-time news search for Research Synthesizer (Crew 1)
# When set, each asset is searched for live news BEFORE Mistral synthesises the ResearchItem.
# This significantly improves catalyst quality and source_quality_score.
# Get your key at: https://www.perplexity.ai/settings/api
# Models used: sonar (fast, default) or sonar-pro (deeper, higher cost)
# PERPLEXITY_API_KEY=replace_with_your_perplexity_key

# Override provider / model (optional — auto-detect is usually fine)
# CREWAI_LLM_PROVIDER=mistral
# CREWAI_LLM_MODEL=mistral-small-latest
